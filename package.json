{
  "name": "s3proxy-docker",
  "description": "Docker runtime for s3proxy (Hono)",
  "version": "4.2.0",
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "NODE_ENV=development node --watch server.js",
    "test": "node --test test/*.test.js",
    "test:app": "node --test test/server.test.js",
    "test:container": "node --test test/docker-basic.test.js",
    "test:watch": "node --test --watch test/*.test.js",
    "test:conformance": "artillery run --config node_modules/@forkzero/s3-website-test-kit/configs/conformance.yml --target ${TARGET:-http://localhost:8080} node_modules/@forkzero/s3-website-test-kit/scenarios/core/conformance.yml",
    "test:load": "artillery run --config node_modules/@forkzero/s3-website-test-kit/configs/docker-container.yml --target ${TARGET:-http://localhost:8080} node_modules/@forkzero/s3-website-test-kit/scenarios/core/load-test.yml",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "credentials": "aws sts get-session-token --duration 900 > credentials.json",
    "docker:build": "docker build -t s3proxy-docker:latest .",
    "docker:run": "docker run --rm -p 8080:8080 -e BUCKET=s3proxy-public s3proxy-docker:latest",
    "docker:test": "docker build --target test -t s3proxy-docker:test . && docker run --rm s3proxy-docker:test",
    "dockerize-for-prod-dockerhub": "docker buildx build --build-arg VERSION=$npm_package_version --push --target production -t forkzero/s3proxy:$npm_package_version -t forkzero/s3proxy:latest --platform=linux/amd64,linux/arm64 .",
    "docker-login-dockerhub": "docker login --username ${DOCKERHUB_USER} --password ${DOCKERHUB_ACCESS_TOKEN}",
    "security:audit": "npm audit --audit-level moderate",
    "deps:update": "npm update",
    "deps:check": "npm outdated"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.0",
    "hono": "^4.12.15",
    "s3proxy": "^4.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@forkzero/s3-website-test-kit": "^0.2.0",
    "artillery": "^2.0.33"
  },
  "keywords": [
    "s3",
    "proxy",
    "hono",
    "docker",
    "aws",
    "streaming",
    "performance",
    "typescript",
    "ai",
    "ml",
    "models"
  ],
  "author": "George Moon <george.moon@gmail.com>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/gmoon/s3proxy-docker.git"
  }
}
